    "def double_list(my_list):\n",
    "    return [x * 2 for x in my_list]\n",
    "\n",
    "# Example\n",
    "my_list = [1, 2, 3, 4, 5]\n",
    "result_list = double_list(my_list)\n",
    "print(\"List Output:\", result_list)"
